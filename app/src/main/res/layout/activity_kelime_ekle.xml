<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FAFAFA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="YENİ KELİME EKLE"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginBottom="25dp"
        android:textColor="#1976D2"/>

    <EditText
        android:id="@+id/editIngilizce"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="İngilizce Kelime Yazın"
        android:background="@android:drawable/editbox_background"
        android:padding="12dp"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btnApiCek"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="API'DEN BİLGİLERİ GETİR"
        android:backgroundTint="#FF5722"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DDDDDD"
        android:layout_marginBottom="20dp"/>

    <EditText
        android:id="@+id/editTurkce"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Türkçe Karşılığı / Tanımı"
        android:background="@android:drawable/editbox_background"
        android:padding="12dp"
        android:layout_marginBottom="15dp"/>

    <EditText
        android:id="@+id/editOrnekCumle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Örnek Cümle"
        android:background="@android:drawable/editbox_background"
        android:padding="12dp"
        android:layout_marginBottom="25dp"
        android:lines="3"
        android:gravity="top"/>

    <Button
        android:id="@+id/btnKelimeKaydet"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="VERİTABANINA KAYDET"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

</LinearLayout>