<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="20dp"
    android:background="#F0F4F8">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ANA MENÜ"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnKelimeEkle"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="KELİME EKLE"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btnKelimeListele"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="KELİMELERİ LİSTELE"
        android:backgroundTint="#2196F3"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btnSinav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="SINAVA BAŞLA"
        android:backgroundTint="#9C27B0"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btnAnaliz"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="BAŞARI ANALİZİ"
        android:backgroundTint="#FF9800"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btnAyarlar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="AYARLAR"
        android:backgroundTint="#607D8B"
        android:textColor="#FFFFFF" />

</LinearLayout>